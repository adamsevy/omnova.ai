---
import Layout from '~/layouts/PageLayout.astro';
import ParticleNetwork from '~/components/ParticleNetwork.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'OmNova - Find What is Hidden. Get a Plan. Move Fast.',
  description: 'Deploy AI teams that analyze everything, synthesize insights, and deliver decision-ready plans—in days, not months.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- SECTION 1: HERO -->
  <section class="hero-section relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 py-20 sm:py-24 md:py-32 lg:py-40 overflow-hidden">
    <!-- Particle Network Background -->
    <ParticleNetwork />
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <!-- Main Headline -->
        <h1 class="hero-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 md:mb-8 leading-tight tracking-tight">
          Find what's hidden.<br />
          Get a plan.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 via-orange-500 to-orange-600">Move fast.</span>
        </h1>
        
        <!-- Subheadline -->
        <p class="hero-subhead text-lg sm:text-xl md:text-2xl text-white/90 max-w-4xl mx-auto mb-8 md:mb-10 leading-relaxed px-4">
          Deploy AI teams that analyze everything, synthesize insights, and deliver decision-ready plans—in days, not months.
        </p>
        
        <!-- Proof Points -->
        <ul class="proof-points flex flex-col sm:flex-row sm:flex-wrap justify-center gap-4 sm:gap-6 text-base md:text-lg text-white/90 mb-10 md:mb-12 px-4 max-w-4xl mx-auto">
          <li class="flex items-center gap-3 justify-center">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-cyan-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>Analyze 100% of everything, not the 1% you had to settle for</span>
          </li>
          <li class="flex items-center gap-3 justify-center">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-cyan-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>Turn 6 months of work into 48 hours</span>
          </li>
          <li class="flex items-center gap-3 justify-center">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-cyan-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>Get answers you can act on immediately</span>
          </li>
        </ul>

        <!-- CTAs -->
        <div class="cta-buttons flex flex-col sm:flex-row gap-4 justify-center mb-12 md:mb-16 px-4">
          <Button variant="primary" size="lg" href="#how-it-works">
            See How It Works
          </Button>
          <Button variant="secondary" size="lg" href="#contact">
            What Can't You See?
          </Button>
        </div>

        <!-- Trust Signal -->
        <p class="text-sm md:text-base text-white/60">
          Trusted by PE firms, franchise networks, and system integrators
        </p>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="scroll-indicator absolute bottom-8 left-1/2 transform -translate-x-1/2 hidden md:block">
      <a href="#social-proof" class="animate-bounce text-white/60 hover:text-white/90 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </section>

  <!-- SECTION 2: SOCIAL PROOF -->
  <section id="social-proof" class="social-proof-section relative bg-gradient-to-b from-primary-900 via-primary-800 to-gray-900 text-white py-16 md:py-20">
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-semibold mb-8 md:mb-12 text-white/90">
        Organizations Using Impossible Teams
      </h2>
      
      <!-- Proof Points (since you may not have logos yet) -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 text-sm md:text-base">
        <div class="proof-item flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-full bg-orange-500/20 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <p class="text-gray-300">PE-backed franchise networks<br />across 40 states</p>
        </div>
        
        <div class="proof-item flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-full bg-cyan-500/20 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <p class="text-gray-300">System integrators<br />serving Fortune 500</p>
        </div>
        
        <div class="proof-item flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-full bg-purple-500/20 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <p class="text-gray-300">Multi-location operators<br />managing 200+ locations</p>
        </div>
        
        <div class="proof-item flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <p class="text-gray-300">Investment firms<br />monitoring thousands of companies</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: THREE CORE JOBS -->
  <section id="three-jobs" class="three-jobs-section relative bg-gradient-to-b from-gray-900 to-gray-950 text-white py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4 md:mb-6 leading-tight">
          Three Jobs That Were Impossible—<br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Until Now</span>
        </h2>
        <p class="text-lg md:text-xl text-gray-400 max-w-3xl mx-auto">
          Not faster. Not cheaper. <span class="text-white font-semibold">Structurally impossible</span> without coordination at scale.
        </p>
      </div>

      <!-- Job Cards -->
      <div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-12">
        <!-- Job 1: Find the Signal -->
        <div class="job-card group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-cyan-500 rounded-2xl p-6 md:p-8 transition-all duration-300 cursor-pointer hover:shadow-xl hover:shadow-cyan-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-cyan-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl md:text-3xl font-bold mb-4 group-hover:text-cyan-400 transition-colors">
            Find the Signal<br />in the Noise
          </h3>
          
          <p class="text-base md:text-lg text-gray-400 group-hover:text-gray-300 transition-colors mb-6">
            When you can't see what matters because there's too much to analyze.
          </p>
          
          <ul class="space-y-3 text-sm md:text-base text-gray-300">
            <li class="flex items-start gap-2">
              <span class="text-cyan-400 mt-1">→</span>
              <span>Review 15,000 companies across 50 languages</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan-400 mt-1">→</span>
              <span>Analyze 100% of documents, not 1%</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan-400 mt-1">→</span>
              <span>Monitor every market, every day</span>
            </li>
          </ul>
          
          <div class="card-expand-hint mt-6 text-sm text-cyan-400 font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
            Click to see example →
          </div>
        </div>

        <!-- Job 2: Build the Plan -->
        <div class="job-card group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-orange-500 rounded-2xl p-6 md:p-8 transition-all duration-300 cursor-pointer hover:shadow-xl hover:shadow-orange-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-orange-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl md:text-3xl font-bold mb-4 group-hover:text-orange-400 transition-colors">
            Turn Complexity<br />Into a Plan
          </h3>
          
          <p class="text-base md:text-lg text-gray-400 group-hover:text-gray-300 transition-colors mb-6">
            When you need insights turned into something you can act on.
          </p>
          
          <ul class="space-y-3 text-sm md:text-base text-gray-300">
            <li class="flex items-start gap-2">
              <span class="text-orange-400 mt-1">→</span>
              <span>Convert 10,000 documents into a decision brief</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-orange-400 mt-1">→</span>
              <span>Build strategies in 48 hours, not 6 months</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-orange-400 mt-1">→</span>
              <span>Get recommendations backed by complete analysis</span>
            </li>
          </ul>
          
          <div class="card-expand-hint mt-6 text-sm text-orange-400 font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
            Click to see example →
          </div>
        </div>

        <!-- Job 3: Compress Time -->
        <div class="job-card group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-purple-500 rounded-2xl p-6 md:p-8 transition-all duration-300 cursor-pointer hover:shadow-xl hover:shadow-purple-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-purple-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl md:text-3xl font-bold mb-4 group-hover:text-purple-400 transition-colors">
            Compress Time<br />to Outcome
          </h3>
          
          <p class="text-base md:text-lg text-gray-400 group-hover:text-gray-300 transition-colors mb-6">
            When speed has direct economic value.
          </p>
          
          <ul class="space-y-3 text-sm md:text-base text-gray-300">
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-1">→</span>
              <span>Deploy 500 analysts overnight</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-1">→</span>
              <span>Turn months into days</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-1">→</span>
              <span>Move while competitors are still planning</span>
            </li>
          </ul>
          
          <div class="card-expand-hint mt-6 text-sm text-purple-400 font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
            Click to see example →
          </div>
        </div>
      </div>

      <!-- Call-out -->
      <div class="text-center">
        <p class="text-xl md:text-2xl text-cyan-400 font-semibold mb-2">
          The constraint is no longer resources.
        </p>
        <p class="text-2xl md:text-3xl text-white font-bold">
          It's imagination.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 4: BEFORE/AFTER -->
  <section class="before-after-section relative bg-gradient-to-b from-gray-950 via-gray-900 to-gray-950 text-white py-20 md:py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6">
          The Old Way vs. <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">The New Reality</span>
        </h2>
      </div>

      <!-- Split Comparison -->
      <div class="grid md:grid-cols-2 gap-8 md:gap-12">
        <!-- OLD WAY -->
        <div class="comparison-col old-way bg-gray-800/30 border border-gray-700 rounded-2xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-red-500/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-gray-400">The Old Way</h3>
          </div>
          
          <ul class="space-y-4 text-sm md:text-base text-gray-400">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
              <span>Hire 50 analysts? Months of recruiting, millions in cost</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
              <span>Review 1% of documents because 100% is impossible</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
              <span>Coordinate across time zones, cultures, politics</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
              <span>Choose: speed, quality, or cost. Pick two.</span>
            </li>
          </ul>
        </div>

        <!-- NEW REALITY -->
        <div class="comparison-col new-way bg-gradient-to-br from-cyan-900/30 to-blue-900/30 border-2 border-cyan-500/50 rounded-2xl p-6 md:p-8 shadow-xl shadow-cyan-500/10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-cyan-500/30 flex items-center justify-center">
              <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-white">The New Reality</h3>
          </div>
          
          <ul class="space-y-4 text-sm md:text-base text-gray-100">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Deploy 500 AI specialists in 48 hours</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Analyze 100% of everything, simultaneously</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Zero meetings, zero politics, perfect coordination</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Get all three: speed, quality, AND scale</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-12 md:mt-16">
        <a href="#examples" class="inline-flex items-center text-cyan-400 hover:text-cyan-300 transition group text-base md:text-lg font-semibold">
          <span>See what becomes possible</span>
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 5: EXAMPLES -->
