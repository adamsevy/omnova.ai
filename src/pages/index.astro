---
import Layout from '~/layouts/PageLayout.astro';
import ParticleNetwork from '~/components/ParticleNetwork.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: "OmNova — Deploy Impossible Teams",
  description: "Illuminate the invisible. Engineer foresight. Orchestrate adaptation. Deploy AI teams that execute work that didn't exist before.",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- SECTION 1: HERO -->
  <section class="hero-section relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 py-20 sm:py-24 md:py-32 lg:py-40 overflow-hidden">
    <ParticleNetwork />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 md:mb-8 leading-tight tracking-tight">
          Illuminate the Invisible.<br />
          Engineer Foresight.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 via-orange-500 to-orange-600">Orchestrate Adaptation.</span>
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-white/90 max-w-4xl mx-auto mb-8 md:mb-10 leading-relaxed px-4">
          Deploy AI teams that analyze everything, synthesize insights, predict what's next, and adapt autonomously—compressing months of work into days.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 md:mb-16 px-4">
          <Button variant="primary" size="lg" href="#how-it-works">
            See Dynamis in Action
          </Button>
          <Button variant="secondary" size="lg" href="#contact">
            What's Your Impossible Job?
          </Button>
        </div>
        <p class="text-sm md:text-base text-white/60">
          Trusted by PE firms, franchise networks, and system integrators
        </p>
      </div>
    </div>
    <div class="scroll-indicator absolute bottom-8 left-1/2 transform -translate-x-1/2 hidden md:block">
      <a href="#value-prop" class="animate-bounce text-white/60 hover:text-white/90 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </section>

  <!-- SECTION 2: UNIVERSAL VALUE PROP -->
  <section id="value-prop" class="relative bg-slate-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Compress Time to Outcome
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        The constraint is no longer resources. It's imagination. We're defining a new asset class of human capability: <span class="text-cyan-400 font-semibold">Permissionless Genius</span>.
      </p>
    </div>
  </section>

  <!-- SECTION 3: FOUR CORE JOBS -->
  <section id="core-jobs" class="relative bg-gradient-to-b from-slate-900 to-gray-900 text-white py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 md:mb-6">
          Four Core Jobs
        </h2>
        <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto">
          Built for organizations where complexity is the constraint and speed has economic value.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        <!-- Job 1 -->
        <div class="group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-cyan-500 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:shadow-xl hover:shadow-cyan-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-cyan-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 group-hover:text-cyan-400 transition-colors">1. Illuminate the Invisible</h3>
          <p class="text-slate-300 leading-relaxed">
            Discover structural truth hidden in massive, multidimensional noise. Find what's hidden before the market prices it in. Analyze 100% of everything, not the 1% you had to settle for.
          </p>
        </div>

        <!-- Job 2 -->
        <div class="group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-orange-500 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:shadow-xl hover:shadow-orange-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-orange-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 group-hover:text-orange-400 transition-colors">2. Deliver Hyper-Contextual Guidance</h3>
          <p class="text-slate-300 leading-relaxed">
            Don't just hand you a report—actively coach you through complexity, step-by-step. Scale bespoke mentorship infinitely with Impossible Guides that adapt to your exact situation in real-time.
          </p>
        </div>

        <!-- Job 3 -->
        <div class="group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-purple-500 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:shadow-xl hover:shadow-purple-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-purple-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 group-hover:text-purple-400 transition-colors">3. Engineer Contextual Foresight</h3>
          <p class="text-slate-300 leading-relaxed">
            Simulate second-order scenarios before your competitors realize what's happening. Predict behavioral economics, geopolitical shifts, and hyperlocal market dynamics to identify profitable asymmetries.
          </p>
        </div>

        <!-- Job 4 -->
        <div class="group bg-gray-800/50 backdrop-blur border-2 border-gray-700 hover:border-green-500 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:shadow-xl hover:shadow-green-500/20 hover:-translate-y-1">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-green-500/20 mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 group-hover:text-green-400 transition-colors">4. Orchestrate Autonomous Adaptation</h3>
          <p class="text-slate-300 leading-relaxed">
            Monitor reality and adapt continuously without human bottlenecks. Execute, recalibrate, and optimize 24/7 with perfect coordination—no meetings, no politics, full transparency.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: OLD WAY VS NEW REALITY -->
  <section class="relative bg-gradient-to-b from-gray-950 via-gray-900 to-gray-950 text-white py-20 md:py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6">
          The Old Way vs. <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">The New Reality</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12">
        <!-- Old Way -->
        <div class="bg-gray-800/30 border border-gray-700 rounded-2xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-red-500/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-gray-400">The Old Way</h3>
          </div>
          <ul class="space-y-4 text-gray-400">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
              <span>Sample 1% of data, guess at the rest</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
              <span>6+ months for basic market research</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
              <span>One-size-fits-all recommendations</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
              <span>Decisions based on outdated snapshots</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
              <span>Bottlenecked by human coordination</span>
            </li>
          </ul>
        </div>

        <!-- New Reality -->
        <div class="bg-gradient-to-br from-cyan-900/30 to-blue-900/30 border-2 border-cyan-500/50 rounded-2xl p-6 md:p-8 shadow-xl shadow-cyan-500/10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-cyan-500/30 flex items-center justify-center">
              <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-white">The New Reality</h3>
          </div>
          <ul class="space-y-4 text-gray-100">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span>Analyze 100% of everything, synthesize insights instantly</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span>Turn 6 months of work into 48 hours</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span>Hyper-contextual guidance tailored to your exact situation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span>Continuous foresight that adapts to shifting reality</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span>Your team makes decisions. AI teams execute everything else—24/7, perfectly coordinated, full transparency</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: WORK THAT DIDN'T EXIST BEFORE -->
  <section id="examples" class="relative bg-gradient-to-b from-gray-950 to-gray-900 text-white py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 md:mb-6">
          Work That Didn't Exist Before
        </h2>
        <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto">
          Not faster. Not cheaper. Structurally impossible without coordination at unprecedented scale.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        <div class="group bg-gray-800/50 border-2 border-gray-700 hover:border-cyan-500 rounded-2xl p-6 transition-all hover:shadow-xl hover:shadow-cyan-500/20 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-cyan-400 transition-colors">Hyperlocal Intelligence Across Your Entire Portfolio</h3>
          <p class="text-slate-300 mb-4 text-sm leading-relaxed">
            For PE/VC firms: Synergistic entry-only via portfolio relationships. Hyperlocal due diligence at ZIP-code level, post-acquisition growth intelligence for multi-location businesses, and continuous opportunity/risk watchtowers.
          </p>
          <div class="text-xs text-cyan-400 font-semibold">Core Jobs: Illuminate + Engineer Foresight</div>
        </div>

        <div class="group bg-gray-800/50 border-2 border-gray-700 hover:border-orange-500 rounded-2xl p-6 transition-all hover:shadow-xl hover:shadow-orange-500/20 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-orange-400 transition-colors">Impossible Guides That Adapt in Real-Time</h3>
          <p class="text-slate-300 mb-4 text-sm leading-relaxed">
            Deploy AI coaches that understand your exact situation and actively guide you through complexity—step-by-step. From pre-legal prep to hyperlocal trip planning to personalized learning paths that scale infinitely.
          </p>
          <div class="text-xs text-orange-400 font-semibold">Core Job: Deliver Hyper-Contextual Guidance</div>
        </div>

        <div class="group bg-gray-800/50 border-2 border-gray-700 hover:border-purple-500 rounded-2xl p-6 transition-all hover:shadow-xl hover:shadow-purple-500/20 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-purple-400 transition-colors">Monitor 15,000 Markets, Run 1,000 Localized Campaigns</h3>
          <p class="text-slate-300 mb-4 text-sm leading-relaxed">
            For franchise networks and multi-location operators: Continuous hyperlocal intelligence, autonomous campaign orchestration, and predictive expansion modeling across every market simultaneously.
          </p>
          <div class="text-xs text-purple-400 font-semibold">Core Jobs: Orchestrate Adaptation + Illuminate</div>
        </div>

        <div class="group bg-gray-800/50 border-2 border-gray-700 hover:border-yellow-500 rounded-2xl p-6 transition-all hover:shadow-xl hover:shadow-yellow-500/20 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-yellow-400 transition-colors">Stress-Test Illiquid Assets Against Geopolitical Shifts</h3>
          <p class="text-slate-300 mb-4 text-sm leading-relaxed">
            For RIAs and hedge funds: Integrate macro trends, hyperlocal demographics, and climate/resource data. Simulate decades of cascading effects to optimize long-term capital allocation with contextual foresight.
          </p>
          <div class="text-xs text-yellow-400 font-semibold">Core Jobs: Engineer Foresight + Orchestrate Adaptation</div>
        </div>

        <div class="group bg-gray-800/50 border-2 border-gray-700 hover:border-red-500 rounded-2xl p-6 transition-all hover:shadow-xl hover:shadow-red-500/20 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-red-400 transition-colors">Deep-Tier Supply Chain Risk Intelligence</h3>
          <p class="text-slate-300 mb-4 text-sm leading-relaxed">
            Monitor hyperlocal news in native languages near critical Tier 3/4 suppliers. Predict disruptions before they cascade. Trigger adaptive smart-contracts for alternative sourcing autonomously.
          </p>
          <div class="text-xs text-red-400 font-semibold">Core Jobs: Illuminate + Orchestrate Adaptation</div>
        </div>

        <div class="group bg-gray-800/50 border-2 border-gray-700 hover:border-pink-500 rounded-2xl p-6 transition-all hover:shadow-xl hover:shadow-pink-500/20 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-pink-400 transition-colors">Hyper-Personalized Narrative Guides at Scale</h3>
          <p class="text-slate-300 mb-4 text-sm leading-relaxed">
            For massive entertainment IPs: Generate dynamically adapting guides for millions of fans based on psychological profiles and engagement history. From Impossible Books to fan orchestration.
          </p>
          <div class="text-xs text-pink-400 font-semibold">Core Job: Deliver Hyper-Contextual Guidance</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: HOW IT WORKS -->
  <section id="how-it-works" class="relative bg-gradient-to-b from-gray-900 to-primary-900 text-white py-20 md:py-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 md:mb-6">
          How Dynamis Works
        </h2>
        <p class="text-lg md:text-xl text-gray-400">
          Four steps. No meetings. No politics. Just results.
        </p>
      </div>

      <div class="space-y-12 md:space-y-16 relative">
        <div class="timeline-line absolute left-8 top-16 bottom-16 w-0.5 bg-gradient-to-b from-cyan-500 via-orange-500 to-purple-500 hidden md:block"></div>

        <div class="flex flex-col md:flex-row items-start gap-6 md:gap-8 relative">
          <div class="flex-shrink-0 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center text-2xl md:text-3xl font-bold shadow-xl z-10">1</div>
          <div class="flex-1">
            <h3 class="text-2xl md:text-3xl font-bold mb-3 md:mb-4">Deploy Your Impossible Team</h3>
            <p class="text-base md:text-lg text-gray-300 leading-relaxed">Assemble specialized AI agents configured for your exact job. Each agent masters a domain: research, synthesis, prediction, execution.</p>
          </div>
        </div>

        <div class="flex flex-col md:flex-row items-start gap-6 md:gap-8 relative">
          <div class="flex-shrink-0 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-2xl md:text-3xl font-bold shadow-xl z-10">2</div>
          <div class="flex-1">
