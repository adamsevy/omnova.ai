---
import Logo from '~/components/Logo.astro';

import type { CallToAction } from '~/types';

export interface Props {
  id?: string;
  links?: Array<{
    text?: string;
    href?: string;
    ariaLabel?: string;
  }>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
} = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;
---

<header
  class="absolute top-0 left-0 right-0 z-50 w-full"
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
          <Logo />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {links.map(({ text, href, ariaLabel }) => (
          <a
            href={href}
            aria-label={ariaLabel}
            class="text-white/90 hover:text-cyan-400 transition-colors font-medium text-sm"
          >
            {text}
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center">
        {actions?.length ? (
          actions.map((btnProps) => (
            <a
              {...btnProps}
              class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-orange-500 to-orange-600 rounded-lg hover:from-orange-600 hover:to-orange-700 transition-all duration-200 hover:shadow-lg hover:shadow-orange-500/25 hover:-translate-y-0.5"
            >
              {btnProps.text}
            </a>
          ))
        ) : null}
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <button
          type="button"
          class="text-white hover:text-cyan-400 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    background: transparent;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
</style>
