---
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

const navigation = [
  { text: 'Three Jobs', href: '#three-jobs' },
  { text: 'Examples', href: '#examples' },
  { text: 'How It Works', href: '#how-it-works' },
];
---

<header class="header-new fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-20 md:h-24">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="logo-link inline-block transition-opacity hover:opacity-80" aria-label="OmNova home">
          <Logo />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8 lg:gap-12">
        {navigation.map((item) => (
          <a
            href={item.href}
            class="nav-link text-base lg:text-lg font-medium text-white/80 hover:text-white transition-colors relative"
          >
            {item.text}
          </a>
        ))}
      </div>

      <!-- CTA Button (Desktop) -->
      <div class="hidden md:block">
        <a
          href="#contact"
          class="inline-flex items-center px-6 lg:px-8 py-3 lg:py-3.5 text-base lg:text-lg font-bold rounded-full bg-gradient-to-r from-orange-500 to-orange-600 text-white hover:from-orange-600 hover:to-orange-700 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          Start Conversation
        </a>
      </div>

      <!-- Mobile Menu Toggle -->
      <div class="md:hidden">
        <ToggleMenu />
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu fixed inset-0 bg-primary-900/98 backdrop-blur-lg z-40 md:hidden opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="flex flex-col items-center justify-center h-full gap-8 px-8">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link text-2xl font-bold text-white/90 hover:text-white transition-colors"
        >
          {item.text}
        </a>
      ))}
      <a
        href="#contact"
        class="inline-flex items-center px-10 py-4 text-xl font-bold rounded-full bg-gradient-to-r from-orange-500 to-orange-600 text-white shadow-xl mt-4"
      >
        Start Conversation
      </a>
    </div>
  </div>
</header>

<style>
  /* Header background transitions */
  .header-new {
    background: transparent;
  }

  .header-new.scrolled {
    background: rgba(30, 58, 138, 0.95);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  /* Nav link hover effect */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #f97316, #ea580c);
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* Mobile menu active state */
  .mobile-menu.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Logo link smooth scroll */
  .logo-link {
    cursor: pointer;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('.header-new');
    const mobileMenuToggle = document.querySelector('[data-aw-toggle-menu]');
    const mobileMenu = document.querySelector('.mobile-menu');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

    // Header scroll effect
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      
      if (currentScroll > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
      
      lastScroll = currentScroll;
    });

    // Mobile menu toggle
    mobileMenuToggle?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('active');
      document.body.style.overflow = mobileMenu?.classList.contains('active') ? 'hidden' : '';
    });

    // Close mobile menu on link click
    mobileNavLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.remove('active');
        document.body.style.overflow = '';
      });
    });

    // Smooth scroll for all navigation links
    const allNavLinks = document.querySelectorAll('.nav-link, .mobile-nav-link, a[href="#contact"]');
    allNavLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href?.startsWith('#')) {
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) {
            const headerHeight = header?.offsetHeight || 0;
            const targetPosition = target.offsetTop - headerHeight;
            window.scrollTo({
              top: targetPosition,
              behavior: 'smooth'
            });
          }
        }
      });
    });

    // Logo click - smooth scroll to top
    const logoLink = document.querySelector('.logo-link');
    logoLink?.addEventListener('click', (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
