---
import Layout from '~/layouts/PageLayout.astro';
import ParticleNetwork from '~/components/ParticleNetwork.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'OmNova — Potential Becoming Actuality. At Scale.',
  description: 'Deploy an agentic team that discovers what you\'re capable of, builds the plan to get there, and executes it alongside you — from day one.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- SECTION 1: HERO -->
  <section class="hero-section relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 py-20 sm:py-24 md:py-32 lg:py-40 overflow-hidden">
    <ParticleNetwork />

    <!-- Subtle gold vignette overlay for premium feel -->
    <div class="absolute inset-0 bg-gradient-radial from-transparent via-transparent to-black/40 pointer-events-none"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">

        <!-- Main Headline -->
        <h1 class="hero-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 md:mb-8 leading-[1.05] tracking-tight">
          Your potential is expanding.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-300 via-orange-400 to-amber-400">Resources are no longer the constraint.</span>
        </h1>

        <!-- Subheadline -->
        <p class="hero-subhead text-lg sm:text-xl md:text-2xl text-white/80 max-w-3xl mx-auto mb-10 md:mb-12 leading-relaxed px-4 font-light">
          Agentic guides and teams built for your ambition — and the scale to match it.
        </p>

        <!-- Proof Points -->
        <ul class="proof-points flex flex-col sm:flex-row sm:flex-wrap justify-center gap-3 sm:gap-5 text-sm md:text-base text-white/80 mb-10 md:mb-14 px-4 max-w-4xl mx-auto">
          <li class="flex items-center gap-3 justify-center bg-white/5 border border-white/10 rounded-full px-5 py-2.5 backdrop-blur-sm">
            <svg class="w-4 h-4 text-orange-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>From scarcity mindset to abundance orientation — in days, not months</span>
          </li>
          <li class="flex items-center gap-3 justify-center bg-white/5 border border-white/10 rounded-full px-5 py-2.5 backdrop-blur-sm">
            <svg class="w-4 h-4 text-orange-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>A Chief of Staff, a coach, and an entire workforce — activated on day one</span>
          </li>
          <li class="flex items-center gap-3 justify-center bg-white/5 border border-white/10 rounded-full px-5 py-2.5 backdrop-blur-sm">
            <svg class="w-4 h-4 text-orange-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>Potential becoming actuality. At scale.</span>
          </li>
        </ul>

        <!-- CTA -->
        <div class="cta-buttons flex flex-col sm:flex-row gap-4 justify-center mb-14 md:mb-20 px-4">
          <Button variant="primary" size="lg" href="#contact">
            Start Your Unlock
          </Button>
        </div>

        <!-- Trust Bar -->
        <div class="trust-bar border-t border-white/10 pt-8 md:pt-10">
          <p class="text-xs sm:text-sm text-white/40 uppercase tracking-widest font-semibold mb-0">
            Trusted by individuals, PE firms, franchise networks, and organizations ready to unlock what's next
          </p>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="scroll-indicator absolute bottom-8 left-1/2 transform -translate-x-1/2 hidden md:block">
      <a href="#big-shift" class="animate-bounce text-white/40 hover:text-white/70 transition flex flex-col items-center gap-1">
        <span class="text-xs tracking-widest uppercase text-white/30">Scroll</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </section>


  <!-- SECTION 2: THE BIG SHIFT -->
  <section id="big-shift" class="big-shift-section relative bg-gray-950 py-24 md:py-36 overflow-hidden">

    <!-- Decorative background elements -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-500/30 to-transparent"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-orange-500/5 blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-10 md:mb-14 justify-center">
        <div class="h-px w-8 bg-orange-400/60"></div>
        <span class="text-orange-400 text-xs font-bold tracking-widest uppercase">The Big Shift</span>
        <div class="h-px w-8 bg-orange-400/60"></div>
      </div>

      <!-- Headline -->
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white text-center mb-12 md:mb-16 leading-tight tracking-tight">
        We are living through the<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-300 to-amber-400">third great unlocking.</span>
      </h2>

      <!-- Three unlockings — timeline style -->
      <div class="grid md:grid-cols-3 gap-0 mb-16 md:mb-20">
        <div class="unlock-item group relative px-6 md:px-8 py-8 border-b md:border-b-0 md:border-r border-white/10 text-center">
          <div class="text-4xl md:text-5xl font-bold text-white/10 mb-4 font-mono">01</div>
          <h3 class="text-base md:text-lg font-bold text-white/80 mb-3">The Printing Press</h3>
          <p class="text-sm md:text-base text-gray-500 leading-relaxed">Democratized knowledge. For the first time, ideas could travel faster than people.</p>
        </div>
        <div class="unlock-item group relative px-6 md:px-8 py-8 border-b md:border-b-0 md:border-r border-white/10 text-center">
          <div class="text-4xl md:text-5xl font-bold text-white/10 mb-4 font-mono">02</div>
          <h3 class="text-base md:text-lg font-bold text-white/80 mb-3">The Industrial Revolution</h3>
          <p class="text-sm md:text-base text-gray-500 leading-relaxed">Broke the link between birth and destiny. Merit could finally outrun circumstance.</p>
        </div>
        <div class="unlock-item group relative px-6 md:px-8 py-8 text-center">
          <div class="text-4xl md:text-5xl font-bold text-orange-400/30 mb-4 font-mono">03</div>
          <h3 class="text-base md:text-lg font-bold text-orange-200 mb-3">Now</h3>
          <p class="text-sm md:text-base text-gray-400 leading-relaxed">The forces that have always constrained human potential — expertise, resources, bandwidth — are dissolving.</p>
        </div>
      </div>

      <!-- Body copy -->
      <div class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-lg md:text-xl text-gray-400 leading-relaxed">
          Most people can't see it yet. They're looking through a filter built for a world that no longer exists.
        </p>
        <div class="inline-block border border-orange-400/20 bg-orange-400/5 rounded-2xl px-8 py-6">
          <p class="text-xl md:text-2xl text-white font-semibold leading-snug">
            DYNAMIS removes the filter.<br />
            <span class="text-orange-300 font-normal">Then gives you the team to pursue everything it reveals.</span>
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- SECTION 3: TWO THINGS. INSEPARABLE. -->
  <section id="two-things" class="two-things-section relative bg-gradient-to-b from-gray-950 to-gray-900 py-24 md:py-36 overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 rounded-full bg-cyan-500/5 blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-10 md:mb-14 justify-center">
        <div class="h-px w-8 bg-cyan-400/60"></div>
        <span class="text-cyan-400 text-xs font-bold tracking-widest uppercase">Two Things. Inseparable.</span>
        <div class="h-px w-8 bg-cyan-400/60"></div>
      </div>

      <!-- Headline -->
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white text-center mb-4 leading-tight tracking-tight">
        Unlock you. Then work alongside you.
      </h2>
      <p class="text-center text-gray-500 text-base md:text-lg mb-14 md:mb-20 max-w-xl mx-auto">
        Most platforms do one or the other. DYNAMIS refuses to separate them.
      </p>

      <!-- Two Cards -->
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">

        <!-- Card 1: Unlock -->
        <div class="two-things-card relative bg-gray-800/40 border border-gray-700/60 hover:border-cyan-500/50 rounded-3xl p-8 md:p-10 transition-all duration-500 group overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 bg-cyan-500/5 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:bg-cyan-500/10 transition-all duration-500 blur-2xl"></div>
          <div class="relative">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-cyan-500/15 border border-cyan-500/25 mb-6">
              <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <div class="text-xs font-bold text-cyan-400 tracking-widest uppercase mb-3">Step One</div>
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight">Unlock Your Full Possibility Horizon</h3>
            <p class="text-gray-400 text-base md:text-lg leading-relaxed">
              DYNAMIS reveals what you're actually capable of and builds the complete plan to reach it — not a template, not a framework. Your plan.
            </p>
          </div>
        </div>

        <!-- Card 2: Execute -->
        <div class="two-things-card relative bg-gray-800/40 border border-gray-700/60 hover:border-orange-500/50 rounded-3xl p-8 md:p-10 transition-all duration-500 group overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 bg-orange-500/5 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:bg-orange-500/10 transition-all duration-500 blur-2xl"></div>
          <div class="relative">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-orange-500/15 border border-orange-500/25 mb-6">
              <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div class="text-xs font-bold text-orange-400 tracking-widest uppercase mb-3">Step Two</div>
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight">The Implementer Agent Activates It</h3>
            <p class="text-gray-400 text-base md:text-lg leading-relaxed">
              The Implementer Agent builds and activates the agentic system that executes the plan — so it's live from day one, not a document waiting to be acted on.
            </p>
          </div>
        </div>
      </div>

      <!-- Connector thought -->
      <div class="text-center mt-10 md:mt-14">
        <p class="text-gray-600 text-sm md:text-base italic">
          Discovery without execution is just awareness. Execution without discovery is just motion.<br />
          <span class="text-gray-400 not-italic font-medium">DYNAMIS is the only platform that refuses to give you one without the other.</span>
        </p>
      </div>
    </div>
  </section>


  <!-- SECTION 4: THE IMPLEMENTER -->
  <section id="implementer" class="implementer-section relative bg-gray-900 py-24 md:py-36 overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-purple-900/10 via-transparent to-transparent pointer-events-none"></div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-10 md:mb-14 justify-center">
        <div class="h-px w-8 bg-purple-400/60"></div>
        <span class="text-purple-400 text-xs font-bold tracking-widest uppercase">The Implementer</span>
        <div class="h-px w-8 bg-purple-400/60"></div>
      </div>

      <div class="max-w-3xl mx-auto text-center mb-14 md:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6 leading-tight tracking-tight">
          Most AI tools are never<br />actually used.
        </h2>
        <p class="text-lg md:text-xl text-gray-400 leading-relaxed">
          The plan exists. The potential exists. What's missing is someone who can take the plan, build the system, make the connections, and press the activation button.
        </p>
      </div>

      <!-- The visual emphasis block -->
      <div class="relative rounded-3xl overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-900/40 via-gray-900 to-gray-900 rounded-3xl"></div>
        <div class="absolute inset-0 border border-purple-500/20 rounded-3xl"></div>
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/40 to-transparent"></div>

        <div class="relative px-8 md:px-14 py-12 md:py-16">
          <!-- Three states -->
          <div class="grid md:grid-cols-3 gap-8 md:gap-6 mb-12 md:mb-14">
            <div class="text-center">
              <div class="text-3xl md:text-4xl mb-3">💡</div>
              <div class="text-white font-bold text-lg md:text-xl mb-2">You dream.</div>
              <div class="text-gray-500 text-sm md:text-base">The vision is clear. The ambition is real.</div>
            </div>
            <div class="text-center">
              <div class="text-3xl md:text-4xl mb-3">📋</div>
              <div class="text-white font-bold text-lg md:text-xl mb-2">You intend. You plan.</div>
              <div class="text-gray-500 text-sm md:text-base">The document exists. The intentions are strong.</div>
            </div>
            <div class="text-center relative">
              <!-- Highlight this one -->
              <div class="absolute inset-0 bg-purple-500/10 rounded-2xl -m-2 border border-purple-500/20"></div>
              <div class="relative">
                <div class="text-3xl md:text-4xl mb-3">⚡</div>
                <div class="text-purple-300 font-bold text-lg md:text-xl mb-2">The Implementer Agent builds.</div>
                <div class="text-gray-400 text-sm md:text-base">Takes the plan. Builds the system. Activates everything.</div>
              </div>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-gradient-to-r from-transparent via-purple-500/30 to-transparent mb-10 md:mb-12"></div>

          <!-- Bottom statement -->
          <p class="text-center text-gray-400 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
            The Implementer Agent doesn't wait for permission to begin. It finds the gaps, builds the connections, and hands you a running system — not a roadmap.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- SECTION 5: FOR INDIVIDUALS + FOR ORGANIZATIONS (side by side) -->
  <section id="who-its-for" class="audience-section relative bg-gradient-to-b from-gray-900 to-gray-950 py-24 md:py-36 overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-10 md:mb-16 justify-center">
        <div class="h-px w-8 bg-white/20"></div>
        <span class="text-white/40 text-xs font-bold tracking-widest uppercase">Who It's For</span>
        <div class="h-px w-8 bg-white/20"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-4 md:gap-6 items-stretch">

        <!-- FOR INDIVIDUALS -->
        <div class="audience-card for-individuals relative rounded-3xl overflow-hidden group">
          <!-- Background gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-amber-900/30 via-gray-900 to-gray-950"></div>
          <div class="absolute inset-0 border border-amber-500/20 group-hover:border-amber-500/40 rounded-3xl transition-all duration-500"></div>
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-400/40 to-transparent"></div>
          <div class="absolute bottom-0 right-0 w-64 h-64 bg-amber-500/8 rounded-full blur-3xl pointer-events-none group-hover:bg-amber-500/12 transition-all duration-700"></div>

          <div class="relative p-8 md:p-10 lg:p-12 h-full flex flex-col">
            <!-- Label -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-amber-400/30 bg-amber-400/10 mb-8 self-start">
              <span class="text-amber-300 text-xs font-bold tracking-widest uppercase">For Individuals</span>
            </div>

            <h2 class="text-3xl md:text-4xl font-bold text-white mb-5 leading-tight tracking-tight">
              Meet your Archetype.
            </h2>

            <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8 flex-1">
              The Sage. The Coach. The Drill Sergeant. The Advisor. Chosen by you. Built for you. Showing up every day — tracking your unlocks, celebrating what you've achieved, surfacing what opens next.
            </p>

            <!-- Archetype pills -->
            <div class="flex flex-wrap gap-2 mb-8">
              {['The Sage', 'The Coach', 'The Drill Sergeant', 'The Advisor'].map(archetype => (
                <span class="px-3 py-1.5 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-300 text-xs md:text-sm font-medium">
                  {archetype}
                </span>
              ))}
            </div>

            <div class="border-t border-white/10 pt-6">
              <p class="text-amber-200/70 text-sm md:text-base font-medium italic">
                "This is what it looks like when potential becomes actuality."
              </p>
            </div>
          </div>
        </div>

        <!-- FOR ORGANIZATIONS -->
        <div class="audience-card for-organizations relative rounded-3xl overflow-hidden group">
          <!-- Background gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-900/25 via-gray-900 to-gray-950"></div>
          <div class="absolute inset-0 border border-cyan-500/20 group-hover:border-cyan-500/40 rounded-3xl transition-all duration-500"></div>
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-400/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-cyan-500/8 rounded-full blur-3xl pointer-events-none group-hover:bg-cyan-500/12 transition-all duration-700"></div>

          <div class="relative p-8 md:p-10 lg:p-12 h-full flex flex-col">
            <!-- Label -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-cyan-400/30 bg-cyan-400/10 mb-8 self-start">
              <span class="text-cyan-300 text-xs font-bold tracking-widest uppercase">For Organizations</span>
            </div>

            <h2 class="text-3xl md:text-4xl font-bold text-white mb-5 leading-tight tracking-tight">
              This isn't AI added to what you already have.
            </h2>

            <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8 flex-1">
              It's a reinvented structure — the Emergent Organization — designed from the ground up with the human-agentic partnership as a first-class assumption.
            </p>

            <!-- Key insight -->
            <div class="bg-cyan-500/8 border border-cyan-500/20 rounded-2xl px-5 py-4 mb-8">
              <p class="text-cyan-100 text-sm md:text-base leading-relaxed">
                <span class="font-bold text-cyan-300">More human-centric, not less.</span> When agents carry the cognitive load, humans can finally do what only humans can do.
              </p>
            </div>

            <div class="border-t border-white/10 pt-6">
              <p class="text-cyan-200/70 text-sm md:text-base font-medium italic">
                "Designed from the ground up. Not retrofitted."
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- SECTION 6: FINAL CTA -->
  <section id="contact" class="cta-section relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 py-24 md:py-40 overflow-hidden">

    <div class="absolute inset-0 opacity-30">
      <ParticleNetwork />
    </div>
    <div class="absolute inset-0 bg-gradient-radial from-transparent via-transparent to-black/50 pointer-events-none"></div>
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-400/30 to-transparent"></div>

    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">

      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-10 justify-center">
        <div class="h-px w-8 bg-orange-400/60"></div>
        <span class="text-orange-400 text-xs font-bold tracking-widest uppercase">Begin</span>
        <div class="h-px w-8 bg-orange-400/60"></div>
      </div>

      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-6 md:mb-8 leading-tight tracking-tight">
        What's your unlock?
      </h2>

      <p class="text-lg md:text-xl text-white/70 mb-12 md:mb-14 max-w-2xl mx-auto leading-relaxed font-light">
        The conditions that made your biggest ambitions impossible have changed. Permanently.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14 md:mb-16">
        <Button variant="primary" size="lg" href="mailto:hello@omnova.ai">
          Start the Conversation
        </Button>
      </div>

      <!-- Trust Signals -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 text-sm text-white/40 border-t border-white/10 pt-8">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
          </svg>
