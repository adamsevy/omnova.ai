---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: "OmNova — Deploy Impossible Teams",
  description: "Illuminate the invisible. Engineer foresight. Orchestrate adaptation. Deploy AI teams that execute work that didn't exist before.",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'See Dynamis in Action',
        href: '/#how-it-works',
        icon: 'tabler:arrow-right',
      },
      { 
        text: "What's Your Impossible Job?", 
        href: '/#contact' 
      },
    ]}
  >
    <Fragment slot="title">
      Illuminate the Invisible.<br />
      Engineer Foresight.<br />
      <span class="text-accent">Orchestrate Adaptation.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Deploy AI teams that analyze everything, synthesize insights, predict what's next, and adapt autonomously—compressing months of work into days.
    </Fragment>
  </Hero>

  <!-- Universal Value Prop -->
  <section class="py-16 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Compress Time to Outcome
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        The constraint is no longer resources. It's imagination. We're defining a new asset class of human capability: <span class="text-cyan-400 font-semibold">Permissionless Genius</span>.
      </p>
    </div>
  </section>

  <!-- Four Core Jobs -->
  <Features
    id="core-jobs"
    title="Four Core Jobs"
    subtitle="Built for organizations where complexity is the constraint and speed has economic value."
    items={[
      {
        title: '1. Illuminate the Invisible',
        description: "Discover structural truth hidden in massive, multidimensional noise. Find what's hidden before the market prices it in. Analyze 100% of everything, not the 1% you had to settle for.",
        icon: 'tabler:eye',
      },
      {
        title: '2. Deliver Hyper-Contextual Guidance',
        description: "Don't just hand you a report—actively coach you through complexity, step-by-step. Scale bespoke mentorship infinitely with Impossible Guides that adapt to your exact situation in real-time.",
        icon: 'tabler:compass',
      },
      {
        title: '3. Engineer Contextual Foresight',
        description: "Simulate second-order scenarios before your competitors realize what's happening. Predict behavioral economics, geopolitical shifts, and hyperlocal market dynamics to identify profitable asymmetries.",
        icon: 'tabler:crystal-ball',
      },
      {
        title: '4. Orchestrate Autonomous Adaptation',
        description: "Monitor reality and adapt continuously without human bottlenecks. Execute, recalibrate, and optimize 24/7 with perfect coordination—no meetings, no politics, full transparency.",
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- The Old Way vs. The New Reality -->
  <section class="py-16 bg-gradient-to-br from-slate-900 to-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">
        The Old Way vs. The New Reality
      </h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Old Way -->
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-8">
          <h3 class="text-2xl font-bold text-red-400 mb-6">The Old Way</h3>
          <ul class="space-y-4 text-slate-300">
            <li class="flex items-start">
              <span class="text-red-400 mr-3">✗</span>
              <span>Sample 1% of data, guess at the rest</span>
            </li>
            <li class="flex items-start">
              <span class="text-red-400 mr-3">✗</span>
              <span>6+ months for basic market research</span>
            </li>
            <li class="flex items-start">
              <span class="text-red-400 mr-3">✗</span>
              <span>One-size-fits-all recommendations</span>
            </li>
            <li class="flex items-start">
              <span class="text-red-400 mr-3">✗</span>
              <span>Decisions based on outdated snapshots</span>
            </li>
            <li class="flex items-start">
              <span class="text-red-400 mr-3">✗</span>
              <span>Bottlenecked by human coordination</span>
            </li>
          </ul>
        </div>

        <!-- New Reality -->
        <div class="bg-gradient-to-br from-cyan-900/20 to-blue-900/20 border border-cyan-500/30 rounded-xl p-8">
          <h3 class="text-2xl font-bold text-cyan-400 mb-6">The New Reality</h3>
          <ul class="space-y-4 text-slate-200">
            <li class="flex items-start">
              <span class="text-cyan-400 mr-3">✓</span>
              <span>Analyze 100% of everything, synthesize insights instantly</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 mr-3">✓</span>
              <span>Turn 6 months of work into 48 hours</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 mr-3">✓</span>
              <span>Hyper-contextual guidance tailored to your exact situation</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 mr-3">✓</span>
              <span>Continuous foresight that adapts to shifting reality</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 mr-3">✓</span>
              <span>Your team makes decisions. AI teams execute everything else—24/7, perfectly coordinated, with full transparency</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Examples / Use Cases -->
  <section id="examples" class="py-16 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Work That Didn't Exist Before
        </h2>
        <p class="text-xl text-slate-300 max-w-3xl mx-auto">
          Not faster. Not cheaper. Structurally impossible without coordination at unprecedented scale.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- PE/VC Synergistic Intelligence -->
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/50 transition-all">
          <h3 class="text-xl font-bold text-white mb-3">Hyperlocal Intelligence Across Your Entire Portfolio</h3>
          <p class="text-slate-300 mb-4">
            For PE/VC firms: Synergistic entry-only via portfolio relationships. Hyperlocal due diligence at ZIP-code level, post-acquisition growth intelligence for multi-location businesses, and continuous opportunity/risk watchtowers.
          </p>
          <div class="text-sm text-cyan-400">
            Core Jobs: Illuminate + Engineer Foresight
          </div>
        </div>

        <!-- Impossible Guides -->
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/50 transition-all">
          <h3 class="text-xl font-bold text-white mb-3">Impossible Guides That Adapt in Real-Time</h3>
          <p class="text-slate-300 mb-4">
            Deploy AI coaches that understand your exact situation and actively guide you through complexity—step-by-step. From pre-legal prep to hyperlocal trip planning to personalized learning paths that scale infinitely.
          </p>
          <div class="text-sm text-cyan-400">
            Core Job: Deliver Hyper-Contextual Guidance
          </div>
        </div>

        <!-- Multi-Location Operators -->
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/50 transition-all">
          <h3 class="text-xl font-bold text-white mb-3">Monitor 15,000 Markets, Run 1,000 Localized Campaigns</h3>
          <p class="text-slate-300 mb-4">
            For franchise networks and multi-location operators: Continuous hyperlocal intelligence, autonomous campaign orchestration, and predictive expansion modeling across every market simultaneously.
          </p>
          <div class="text-sm text-cyan-400">
            Core Jobs: Orchestrate Adaptation + Illuminate
          </div>
        </div>

        <!-- Contextual Wealth Management -->
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/50 transition-all">
          <h3 class="text-xl font-bold text-white mb-3">Stress-Test Illiquid Assets Against Geopolitical Shifts</h3>
          <p class="text-slate-300 mb-4">
            For RIAs and hedge funds: Integrate macro trends, hyperlocal demographics, and climate/resource data. Simulate decades of cascading effects to optimize long-term capital allocation with contextual foresight.
          </p>
          <div class="text-sm text-cyan-400">
            Core Jobs: Engineer Foresight + Orchestrate Adaptation
          </div>
        </div>

        <!-- Supply Chain Intelligence -->
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/50 transition-all">
          <h3 class="text-xl font-bold text-white mb-3">Deep-Tier Supply Chain Risk Intelligence</h3>
          <p class="text-slate-300 mb-4">
            Monitor hyperlocal news in native languages near critical Tier 3/4 suppliers. Predict disruptions before they cascade. Trigger adaptive smart-contracts for alternative sourcing autonomously.
          </p>
          <div class="text-sm text-cyan-400">
            Core Jobs: Illuminate + Orchestrate Adaptation
          </div>
        </div>

        <!-- IP & Entertainment -->
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/50 transition-all">
          <h3 class="text-xl font-bold text-white mb-3">Hyper-Personalized Narrative Guides at Scale</h3>
          <p class="text-slate-300 mb-4">
            For massive entertainment IPs: Generate dynamically adapting guides for millions of fans based on psychological profiles and engagement history. From Impossible Books to fan orchestration.
          </p>
          <div class="text-sm text-cyan-400">
            Core Job: Deliver Hyper-Contextual Guidance
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <Steps
    id="how-it-works"
    title="How Dynamis Works"
    items={[
      {
        title: 'Deploy Your Impossible Team',
        description: 'Assemble specialized AI agents configured for your exact job. Each agent masters a domain: research, synthesis, prediction, execution.',
        icon: 'tabler:users',
      },
      {
        title: 'They Analyze Everything',
        description: 'Your team ingests structured data, unstructured documents, hyperlocal news, geopolitical signals—100% coverage, not 1% samples.',
        icon: 'tabler:database',
      },
      {
        title: 'Synthesize & Guide',
        description: 'Not just outputs—active guidance. Decision-ready plans, personalized coaching, continuous adaptation. Human oversight, AI execution.',
        icon: 'tabler:route',
      },
      {
        title: 'Adapt Autonomously',
        description: 'Your Impossible Team monitors reality 24/7, recalibrates strategies, triggers workflows, and compresses time to outcome without bottlenecks.',
        icon: 'tabler:refresh-alert',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Dynamis Platform Illustration',
    }}
  />

  <!-- Social Proof / Metrics -->
  <section class="py-16 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">
        Built for High-Stakes, High-Complexity Organizations
      </h2>
      
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl font-bold text-cyan-400 mb-2">100%</div>
          <div class="text-slate-300">Data Coverage<br/>(Not 1% Samples)</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-cyan-400 mb-2">48 Hours</div>
          <div class="text-slate-300">What Used to Take<br/>6 Months</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-cyan-400 mb-2">15,000+</div>
          <div class="text-slate-300">Markets Monitored<br/>Simultaneously</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-cyan-400 mb-2">24/7</div>
          <div class="text-slate-300">Autonomous Adaptation<br/>Zero Bottlenecks</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <CallToAction
    id="contact"
    title="What's Your Impossible Job?"
    subtitle="If your organization is constrained by complexity and speed has economic value, let's talk."
    actions={[
      {
        variant: 'primary',
        text: 'Request a Demo',
        href: '#',
      },
    ]}
  />
</Layout>
